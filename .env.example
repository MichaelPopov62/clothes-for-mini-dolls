# Локально (сайт + /api/send-order): npm run dev:vercel  →  это npx vercel dev
# Просто npx vercel — мастер деплоя/привязки проекта, не режим разработки
# В Vercel: Settings → Environment Variables — те же имена; для боевого сайта включите Production и после изменения сделайте Redeploy.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
# Не задавайте VITE_ORDER_API_URL=http://localhost:... если делаете vite build для продакшена (попадёт в бандл).
# Для dev с отдельным API: VITE_ORDER_API_URL=https://ваш-проект.vercel.app/api/send-order
